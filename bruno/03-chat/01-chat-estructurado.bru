meta {
  name: Chat con salida estructurada
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/agent/chat
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "conversationId": "{{conversationId}}",
    "question": "{{chatQuestion}}"
  }
}

tests {
  test("responde correctamente", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("cumple el contrato AgentAnswer", function () {
    const body = res.getBody();
    expect(body.answer).to.be.a("string").and.not.empty;
    expect(body.sources).to.be.an("array");
    expect(body.toolsUsed).to.be.an("array");
    expect(body.grounded).to.be.a("boolean");
    expect(body.confidence).to.be.a("number").within(0, 1);
    expect(body.warnings).to.be.an("array");
  });
}
