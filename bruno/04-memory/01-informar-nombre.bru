meta {
  name: Informar dato conversacional
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/agent/chat
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "conversationId": "{{memoryConversationId}}",
    "question": "{{memoryStoreQuestion}}"
  }
}

tests {
  test("acepta el primer turno", function () {
    expect(res.getStatus()).to.equal(200);
  });
}
